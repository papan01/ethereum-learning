# --- PostgreSQL (local install; adjust user/password/db name) ---
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ethereum_cathay?schema=public"

# --- apps/api ---
PORT=3001
WEB_ORIGIN="http://localhost:3000"
SIWE_CHAIN_ID=31337

# --- apps/web (Next.js) ---
# Used by Next rewrites in next.config.ts
API_INTERNAL_URL="http://127.0.0.1:3001"

# Browser -> Next proxy path (see apps/web/lib/api.ts)
NEXT_PUBLIC_API_BASE="/api-proxy"

# Must match the wallet chain used for SIWE signatures
NEXT_PUBLIC_SIWE_CHAIN_ID=31337

# Optional: override SIWE `domain` / `uri` (defaults to window.location)
NEXT_PUBLIC_SIWE_DOMAIN="localhost:3000"
NEXT_PUBLIC_SIWE_URI="http://localhost:3000"

# Optional: local Hardhat node RPC (chain 31337)
NEXT_PUBLIC_HARDHAT_RPC_URL="http://127.0.0.1:8545"
